# PORT=5000
# # Encode special chars in password: # → %23, @ → %40. Keep the whole URL in double quotes.
# # Copy exact host from Supabase (may be aws-0 or aws-1). Encode # as %23, @ as %40.
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD-ENCODED]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD-ENCODED]@aws-1-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
# JWT_SECRET=your_jwt_secret_key_here
# JWT_EXPIRES_IN=7d
# CLOUDINARY_CLOUD_NAME=your_cloudinary_name
# CLOUDINARY_API_KEY=your_cloudinary_key
# CLOUDINARY_API_SECRET=your_cloudinary_secret
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=your_twilio_number
# FRONTEND_URL=http://localhost:5173
# NODE_ENV=development
# OTP_TTL_MINUTES=10
# DEV_LOG_OTP=true