# node_modules/
# .env
# dist/
# *.log
# .DS_Store


# ============================================
# AI HEALTH ASSISTANT - ROOT .gitignore
# ============================================

# --------------------------------------------
# EDITOR & IDE
# --------------------------------------------
.vscode/
.claude/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --------------------------------------------
# OS FILES
# --------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# --------------------------------------------
# ENVIRONMENT & SECRETS (NEVER PUSH THESE)
# --------------------------------------------
.env
.env.local
.env.development
.env.production
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
frontend/src/config/env.ts

# --------------------------------------------
# DEPENDENCIES
# --------------------------------------------
node_modules/
backend/node_modules/
frontend/node_modules/

# --------------------------------------------
# BUILD OUTPUT
# --------------------------------------------
dist/
build/
out/
frontend/dist/
frontend/build/

# --------------------------------------------
# CACHE & TEMP
# --------------------------------------------
.vite/
.cache/
*.tsbuildinfo
frontend/.vite/

# --------------------------------------------
# LOGS
# --------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------------------------------
# PRISMA GENERATED
# --------------------------------------------
backend/prisma/generated/

# --------------------------------------------
# TESTING & COVERAGE
# --------------------------------------------
coverage/
.nyc_output/

# --------------------------------------------
# PACKAGE MANAGER
# --------------------------------------------
.yarn/cache
.pnp.*

# ============================================
# FILES YOU MUST ALWAYS PUSH:
# - backend/server.js
# - backend/package.json
# - backend/.env.example
# - backend/prisma/schema.prisma
# - frontend/src/ (all source code)
# - frontend/package.json
# - frontend/index.html
# - frontend/vite.config.ts
# - frontend/tailwind.config.js
# - frontend/tsconfig.json
# - API_DOCS.md
# - postman_collection.json
# - README.md
# ============================================