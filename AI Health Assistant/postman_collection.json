    {
      "name": "Public",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "List Doctors by Specialization",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctors?specialization=Orthopedic",
              "host": ["{{baseUrl}}"],
              "path": ["doctors"],
              "query": [{ "key": "specialization", "value": "Orthopedic" }]
            }
          }
        },
        {
          "name": "List Doctors (doctor/list)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/doctor/list?specialization=Orthopedic",
              "host": ["{{baseUrl}}"],
              "path": ["doctor", "list"],
              "query": [{ "key": "specialization", "value": "Orthopedic" }]
            }
          }
        }
      ]
    },
    {
      "name": "Consultation (Spec)",
      "item": [
        {
          "name": "Submit Consultation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"symptoms\": \"Fever, headache for 2 days\",\n  \"questionAnswers\": { \"duration\": \"2 days\" },\n  \"additionalNotes\": \"No travel\",\n  \"riskLevel\": \"moderate\"\n}"
            },
            "url": "{{baseUrl}}/consultation/submit"
          }
        },
        {
          "name": "Get Consultation By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/consultation/{{consultationId}}"
          }
        },
        {
          "name": "Update Consultation Status",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"reviewed\"\n}"
            },
            "url": "{{baseUrl}}/consultation/{{consultationId}}/status"
          }
        },
        {
          "name": "Get Patient Consultation History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/consultation/patient/{{patientId}}"
          }
        },
        {
          "name": "Get Doctor Consultation History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/consultation/doctor/{{doctorId}}"
          }
        }
      ]
    },
    {
      "name": "Prescription (Spec)",
      "item": [
        {
          "name": "Create Prescription",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"consultationId\": \"{{consultationId}}\",\n  \"patientId\": \"{{patientId}}\",\n  \"diagnosis\": \"Viral fever\",\n  \"medicines\": [\n    {\n      \"name\": \"Paracetamol\",\n      \"dosage\": \"500mg\",\n      \"frequency\": \"Twice daily\",\n      \"duration\": \"5 days\"\n    }\n  ],\n  \"advice\": \"Rest and fluids\"\n}"
            },
            "url": "{{baseUrl}}/prescription/create"
          }
        },
        {
          "name": "Approve Prescription",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/prescription/{{prescriptionId}}/approve"
          }
        },
        {
          "name": "Get Prescription By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/prescription/{{prescriptionId}}"
          }
        },
        {
          "name": "Get Patient Prescription History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/prescription/patient/{{patientId}}"
          }
        },
        {
          "name": "Get Prescription By Consultation",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/prescription/consultation/{{consultationId}}"
          }
        }
      ]
    },
