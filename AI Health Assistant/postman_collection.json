              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. Sameer Patil\",\n  \"phone\": \"9123456789\",\n  \"email\": \"sameer@gmail.com\",\n  \"specialization\": \"Orthopedic\",\n  \"clinicName\": \"City Care Hospital\",\n  \"consultationFee\": 500\n}"
