{
  "info": {
    "_postman_id": "ai-health-assistant-api",
    "name": "AI Health Assistant",
    "description": "Complete API collection for AI Health Assistant backend. Set collection variables: baseUrl, token. See API_DOCS.md for setup guide.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "patientId", "value": "" },
    { "key": "doctorId", "value": "" },
    { "key": "consultationId", "value": "" },
    { "key": "prescriptionId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Patient",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ravi Kadam\",\n  \"phone\": \"9876543210\",\n  \"email\": \"ravi@gmail.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/register/patient"
          }
        },
        {
          "name": "Register Doctor",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Dr. Sameer Patil\",\n  \"phone\": \"9123456789\",\n  \"email\": \"sameer@gmail.com\",\n  \"password\": \"Test@1234\",\n  \"specialization\": \"Orthopedic\",\n  \"licenseNumber\": \"MH-123456\",\n  \"clinicName\": \"City Care Hospital\",\n  \"clinicAddress\": \"Mumbai, Maharashtra\",\n  \"yearsOfExperience\": 10,\n  \"consultationFee\": 500\n}"
            },
            "url": "{{baseUrl}}/auth/register/doctor"
          }
        },
        {
          "name": "Verify Registration OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"patient\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-otp"
          }
        },
        {
          "name": "Login - Email Password OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRole\": \"patient\",\n  \"login_method\": \"email_password_otp\",\n  \"email\": \"ravi@gmail.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login - Mobile OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRole\": \"patient\",\n  \"login_method\": \"mobile_otp\",\n  \"mobile\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Verify Login OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"role\": \"patient\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-login-otp"
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/auth/resend-otp"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ravi@gmail.com\",\n  \"role\": \"patient\"\n}"
