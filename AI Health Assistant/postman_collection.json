          "name": "Login Verify OTP (Legacy)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRole\": \"patient\",\n  \"login_method\": \"email_password_otp\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/login/verify"
          }
        },
        {
          "name": "Login Resend OTP (Legacy)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRole\": \"patient\",\n  \"login_method\": \"email_password_otp\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/auth/login/resend-otp"
          }
        }
      ]
    },
    {
      "name": "Patient (Spec)",
      "item": [
        {
          "name": "Get Patient Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/patient/profile"
          }
        },
        {
          "name": "Update Patient Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ravi Kadam\",\n  \"age\": 28,\n  \"gender\": \"MALE\",\n  \"height\": 175,\n  \"weight\": 70,\n  \"bloodGroup\": \"B+\",\n  \"email\": \"ravi@gmail.com\"\n}"
            },
            "url": "{{baseUrl}}/patient/update-profile"
          }
        },
        {
          "name": "Upload Patient Picture",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "image", "type": "file", "src": [] }]
            },
            "url": "{{baseUrl}}/patient/upload-picture"
          }
        },
        {
          "name": "Get Patient Consultations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/patient/consultations"
          }
        },
        {
          "name": "Get Patient Prescriptions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/patient/prescriptions"
          }
        },
        {
          "name": "Get Medical History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/patient/medical-history"
          }
        },
        {
          "name": "Update Medical History",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chronicDiseases\": [\"Diabetes\"],\n  \"allergies\": [\"Penicillin\"],\n  \"currentMedicines\": [\"Metformin\"]\n}"
            },
            "url": "{{baseUrl}}/patient/medical-history"
          }
        }
      ]
